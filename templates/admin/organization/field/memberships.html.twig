{% extends '@SonataAdmin/CRUD/base_show_field.html.twig' %}

{% block field %}
    {% for membership in value %}
        <p>
            <a href="{{ path('user_show', {'id': membership.getUser().getId()}) }}">{{ membership.getUser().getEmail() }}</a>
            ({{ membership.getRole().value }})
        </p>
    {% else %}
        <p>No members</p>
    {% endfor %}
{% endblock %}
